# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App URL (used for Zaprite redirect after checkout)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Site URL (used for RSS feed, password reset redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Zaprite (payments — Bitcoin, Lightning, card)
ZAPRITE_API_KEY=your-zaprite-api-key
ZAPRITE_WEBHOOK_SECRET=your-zaprite-webhook-secret

# fal.ai (Fox reward image generation)
FAL_KEY=your-fal-key

# API key encryption (used for fal.ai keys, AES-256-GCM, 32 bytes hex-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_ENCRYPTION_KEY=your-64-char-hex-key

# Supabase JWT Secret (used for MCP API key auth — obtain from Supabase Dashboard → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Google Sheets template (public /copy link for curriculum CSV format)
# Create a Google Sheet matching lesson-hollow-template.csv, share as "Anyone with the link can view",
# then use the /copy URL: https://docs.google.com/spreadsheets/d/SHEET_ID/copy
NEXT_PUBLIC_GOOGLE_SHEETS_TEMPLATE_URL=

# Admin player auth user ID — curricula created by this player are
# automatically published (is_public=true). Find via the players table
# joined to auth.users where username='admin'. Leave unset to disable.
ADMIN_PLAYER_AUTH_USER_ID=

# AWS SES (feedback notification emails)
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SES_FROM_EMAIL=noreply@lessonhollow.com
FEEDBACK_NOTIFICATION_EMAIL=owner@lessonhollow.com

# Google Analytics 4 (leave empty to disable tracking)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# E2E test accounts
TEST_PARENT_EMAIL=guide@example.com
TEST_PARENT_PASSWORD=test-password
TEST_STUDENT_USERNAME=player-username
TEST_STUDENT_PASSWORD=test-password
